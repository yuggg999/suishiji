<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Title bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="分类"
            android:textSize="20sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            />
    </LinearLayout>

    <!-- Segment toggle: expense / income -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_segmented"
        android:padding="2dp">

        <View
            android:id="@+id/segment_indicator"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_segment_selected" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_expense"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="支出分类"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_income"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="收入分类"
                android:textSize="14sp"
                android:textColor="@color/segment_unselected" />
        </LinearLayout>
    </FrameLayout>

    <!-- Period switcher: day / month / year -->
    <FrameLayout
        android:id="@+id/stat_period_container"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_segmented"
        android:padding="2dp">

        <View
            android:id="@+id/stat_period_indicator"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_segment_selected" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tab_day"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="日"
                android:textSize="13sp"
                android:textColor="@color/segment_unselected" />

            <TextView
                android:id="@+id/tab_month"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="月"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tab_year"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="年"
                android:textSize="13sp"
                android:textColor="@color/segment_unselected" />
        </LinearLayout>
    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Category stats card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:elevation="2dp">

                <!-- Total amount -->
                <TextView
                    android:id="@+id/tv_stat_total"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="¥0.00"
                    android:textSize="26sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingBottom="16dp"
                    />

                <!-- Bar chart container -->
                <LinearLayout
                    android:id="@+id/bars_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/tv_no_data"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="暂无数据"
                    android:textSize="14sp"
                    android:textColor="@color/text_disabled"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Pie chart card -->
            <LinearLayout
                android:id="@+id/pie_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:elevation="2dp">

                <com.suishiji.view.RingChartView
                    android:id="@+id/pie_chart"
                    android:layout_width="130dp"
                    android:layout_height="130dp" />

                <LinearLayout
                    android:id="@+id/pie_legend"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp" />
            </LinearLayout>

            <!-- Map card -->
            <LinearLayout
                android:id="@+id/map_card"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="12dp"
                android:layout_marginBottom="12dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="地点分布"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <WebView
                    android:id="@+id/web_view"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- Category management list -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="分类管理"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <LinearLayout
                    android:id="@+id/category_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Add button -->
    <TextView
        android:id="@+id/btn_add_category"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+ 新增分类"
        android:textSize="15sp"
        android:textColor="@color/primary"
        android:gravity="center"
        android:padding="16dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_card"
        android:elevation="2dp" />

</LinearLayout>
